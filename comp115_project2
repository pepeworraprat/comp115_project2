def create_subsidized_chart(region_averages):
    """
    Creates a bar chart for average subsidized rate by region.

    Parameters:
        region_averages (dict): average subsidized rate by region
    """
    regions = list(region_averages.keys())
    averages = list(region_averages.values())

    plt.figure(figsize=(10, 6))
    plt.bar(regions, averages)
    plt.title("Average Rental Subsidized Rate by PHA Region")
    plt.xlabel("PHA Region")
    plt.ylabel("Average Subsidized Rate (%)")
    plt.xticks(rotation=30)
    plt.tight_layout()
    plt.show()


