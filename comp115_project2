import csv
import matplotlib.pyplot as plt


def read_csv_file(filename):
    """
    Reads the CSV file and returns a list of dictionaries.

    Parameters:
        filename (str): the CSV file name

    Returns:
        list: a list of rows as dictionaries
    """
    data = []

    with open(filename, "r", encoding="utf-8-sig") as file:
        reader = csv.DictReader(file)
        for row in reader:
            # Convert numeric values from strings to floats
            row["shelt_rent_subsidized_rate"] = float(row["shelt_rent_subsidized_rate"])
            row["shelt_rent_30plus_rate"] = float(row["shelt_rent_30plus_rate"])
            row["shelt_rent_mo_cost_mean"] = float(row["shelt_rent_mo_cost_mean"])
            row["shelt_rent_mo_cost_median"] = float(row["shelt_rent_mo_cost_median"])
            row["income_total_mean"] = float(row["income_total_mean"])
            row["income_total_median"] = float(row["income_total_median"])
            row["income_after_tax_mean"] = float(row["income_after_tax_mean"])
            row["income_after_tax_median"] = float(row["income_after_tax_median"])
            data.append(row)

    return data


