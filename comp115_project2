def find_high_burden_areas(data):
    """
    Finds areas where shelt_rent_30plus_rate > 50.

    Parameters:
        data (list): list of dictionaries

    Returns:
        list: filtered list of high-burden areas
    """
    high_burden = []

    for row in data:
        if row["shelt_rent_30plus_rate"] > 50:
            high_burden.append(row)

    # Sort from highest to lowest shelt_rent_30plus_rate
    high_burden.sort(key=get_30plus_rate, reverse=True)

    return high_burden


def get_30plus_rate(row):
    """
    Returns the shelt_rent_30plus_rate of a row.

    Parameters:
        row (dict): one area row

    Returns:
        float: shelt_rent_30plus_rate
    """
    return row["shelt_rent_30plus_rate"]


