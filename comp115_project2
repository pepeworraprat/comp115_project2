def average_value(data, key):
    """
    Calculates the average of one numeric column.

    Parameters:
        data (list): list of dictionaries
        key (str): column name

    Returns:
        float: average value
    """
    total = 0

    for row in data:
        total += row[key]

    return total / len(data)


def compare_pha_regions(data):
    """
    Compares subsidized rates across PHA regions.

    Parameters:
        data (list): list of dictionaries

    Returns:
        dict: average subsidized rate by region
    """
    region_totals = {}
    region_counts = {}

    for row in data:
        region = row["pha"]
        subsidized_rate = row["shelt_rent_subsidized_rate"]

        if region not in region_totals:
            region_totals[region] = 0
            region_counts[region] = 0

        region_totals[region] += subsidized_rate
        region_counts[region] += 1

    region_averages = {}

    for region in region_totals:
        region_averages[region] = region_totals[region] / region_counts[region]

    return region_averages


